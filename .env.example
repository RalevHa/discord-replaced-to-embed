# Copy to .env and fill in. `npm start` loads this automatically (node --env-file=.env).

# Required: your Discord bot token.
DISCORD_BOT_TOKEN=

# Optional: comma-separated server (guild) IDs the bot acts in. Empty = all servers.
ALLOWED_GUILD_IDS=

# Optional: health-check HTTP port. Defaults to 3000; Render sets this automatically.
PORT=3000

# Optional: Upstash Redis REST credentials. Both required for /toggle and /stats
# to persist across restarts. Leave blank to use in-memory state.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
