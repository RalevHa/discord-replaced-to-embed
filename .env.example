# Copy to .env and fill in. `npm start` loads this automatically (node --env-file=.env).

# Required: your Discord bot token.
DISCORD_BOT_TOKEN=

# Optional: comma-separated server (guild) IDs the bot acts in. Empty = all servers.
ALLOWED_GUILD_IDS=

# Optional: health-check HTTP port. Defaults to 3000; Render sets this automatically.
PORT=3000

# Optional: Facebook posts get a native embed built from scraped Open Graph data
# (no self-hosted proxy or credentials needed). Set to "false" to disable, e.g. if
# Facebook starts blocking your server's IP. Defaults to enabled.
FACEBOOK_EMBED_ENABLED=true

# Optional: Upstash Redis REST credentials. Both required for /toggle and /stats
# to persist across restarts. Leave blank to use in-memory state.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Cross-channel spam (hijacked-account) detection ---
# Detects one member posting the SAME text across many channels in a few seconds,
# then deletes those messages and times the member out.
# Requires the bot to have "Moderate Members" and "Manage Messages" permissions.

# Set to "false" to disable detection entirely. Defaults to enabled.
SPAM_DETECTION_ENABLED=true

# How many distinct channels the same text must hit to trip detection. Default 3.
SPAM_CHANNEL_THRESHOLD=3

# Sliding time window in seconds. Default 15.
SPAM_WINDOW_SECONDS=15

# How long to time the member out, in minutes. Default 10.
SPAM_TIMEOUT_MINUTES=10

# Optional: channel ID where moderation alerts are posted. Empty = console only.
MOD_LOG_CHANNEL_ID=

# Optional: comma-separated role IDs exempt from spam detection.
SPAM_TRUSTED_ROLE_IDS=

# Optional: comma-separated channel IDs to skip (e.g. cross-posted announcements).
SPAM_IGNORED_CHANNEL_IDS=
